# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Gemini AI (Optional - enables AI features)
GEMINI_API_KEY=your_gemini_api_key
ENRICH_WITH_GEMINI=true

# Admin Security (Required for production)
ADMIN_SECRET_PASSWORD=your_strong_password_here
ADMIN_EMAILS=admin@example.com

# Scraper Configuration (Optional)
SCRAPE_SECRET=your_scrape_secret
SCRAPER_DEVFOLIO_ENABLED=true
SCRAPER_UNSTOP_ENABLED=true
SCRAPER_DEVFOLIO_PLAYWRIGHT=false

# Devfolio API (Optional)
DEVFOLIO_API=your_devfolio_api_key
DEVFOLIO_SEARCH_URL=https://devfolio.co/api/events

# Map Configuration (Optional)
NEXT_PUBLIC_MAPBOX_STATIC_PREVIEW_URL=your_mapbox_url