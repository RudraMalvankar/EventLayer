# ──────────────────────────────────────────────
# EventLayer.dev — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in values
# cp .env.example .env.local

# ──────────────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────────────

# Supabase (get these from your Supabase project dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Site URL (used for auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Gemini API key (for AI search & enrichment)
GEMINI_API_KEY=

# Secret used to authenticate manual scrape triggers
SCRAPE_SECRET=

# Set to "true" to enable Gemini enrichment of events
ENRICH_WITH_GEMINI=true

# Comma-separated list of admin email addresses
ADMIN_EMAILS=your@email.com

# ──────────────────────────────────────────────
# OPTIONAL
# ──────────────────────────────────────────────

# Resend (for email digests & onboarding)
RESEND_API_KEY=
RESEND_FROM=EventLayer <onboarding@yourdomain.com>

# Admin cookie session secret
ADMIN_SESSION_SECRET=

# Supabase database password (for local CLI operations)
SUPABASE_DB_PASSWORD=

# Scraper-specific configuration
DEVFOLIO_API=
DEVFOLIO_SEARCH_URL=
SCRAPER_DEVFOLIO_PLAYWRIGHT=false
SCRAPER_DEVFOLIO_ENABLED=true
SCRAPER_UNSTOP_ENABLED=true