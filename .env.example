# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- Site URL (required on Vercel — fixes auth emails redirecting to localhost) ---
NEXT_PUBLIC_SITE_URL=https://eventlayer-dev.vercel.app

# --- AI / scrapers ---
GEMINI_API_KEY=
SCRAPE_SECRET=
ENRICH_WITH_GEMINI=true

# --- Admin ---
ADMIN_EMAILS=rudracmalvankar@gmail.com

# --- Email subscriptions (optional — sends real welcome email) ---
RESEND_API_KEY=
RESEND_FROM=EventLayer <onboarding@yourdomain.com>

# --- Database CLI (optional — npm run db:admin / db:extensions) ---
SUPABASE_DB_PASSWORD=

# --- Vercel auto-set (do not add manually) ---
# VERCEL_URL=
